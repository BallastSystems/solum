SOLUM_WINNERS_FILE=/var/www/solum-data/winners.json
SOLUM_SNAPSHOT_DIR=/var/www/solum-data/snapshots
SOLUM_FEE_STATE=/opt/solum/state/fee-state.json

# claim service (stock fields are loaded but unused by the claim-recording path)
SOLUM_SITE_ORIGIN=https://solum.work
PORT=8787
