# ── Solum host environment ─────────────────────────────────────────────────────
# Copy to /opt/solum/.env on the host and fill the two <LAUNCH> values. NEVER commit this
# file with secrets. The ops key is a FILE path (the key itself never goes in env text).

# --- cluster + wallet ---
SOLUM_RPC=https://api.mainnet-beta.solana.com   # STRONGLY recommend a paid RPC (Helius/Triton) for reliability
SOLUM_OPS_KEY=/opt/solum/secrets/solum-ops.json # the DWtw…6ZX8 keypair (chmod 600, host-only, never git)
SOLUM_IDL=/opt/solum/app/target/idl/solum-prod.json  # PRODUCTION IDL (switchboard-vrf) — NOT the devnet idl

# --- program + protocol wiring (already deployed / verified) ---
SOLUM_PROGRAM_ID=4YCL5cQvVSiVbpN2QVbk82aLuNBqiNt2KbGdqkUKMojY
SOLUM_ADMIN=DWtwwotUi9v7ziFKLNwTpzGdPVZXPFQaRAGijZhJ6ZX8   # jackpot PDA is derived from coinMint + this
SOLUM_VRF=switchboard
SOLUM_COUNTDOWN=300        # fixed 5-minute snapshot→draw countdown
SOLUM_EPOCH_LEN=3600       # 1-hour epochs
SOLUM_SNAP_MIN=480         # snapshot fires at a random point in [8min, 50min] of the hour
SOLUM_SNAP_MAX=3000
SOLUM_FEE_POLL=20          # creator-fee poll cadence (seconds) → drives the live counter

