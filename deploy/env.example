# ── Solum host environment ─────────────────────────────────────────────────────
# Copy to /opt/solum/.env and fill the <LAUNCH> values. NEVER commit this with secrets.
# IMPORTANT: systemd EnvironmentFile does NOT strip inline "# comments" from a value line —
# keep every comment on its OWN line (as below), never after a value.

# cluster + wallet
# SOLUM_RPC: a paid RPC (Helius/Triton) is more reliable, but a free tier is fine for this volume.
SOLUM_RPC=https://api.mainnet-beta.solana.com
# SOLUM_OPS_KEY: the DWtw…6ZX8 keypair FILE path (chmod 600, host-only, never git).
SOLUM_OPS_KEY=/opt/solum/secrets/solum-ops.json
# SOLUM_IDL: the PRODUCTION IDL (switchboard-vrf) — NOT the devnet idl.
SOLUM_IDL=/opt/solum/app/target/idl/solum-prod.json

# program + protocol wiring (already deployed / verified)
SOLUM_PROGRAM_ID=4YCL5cQvVSiVbpN2QVbk82aLuNBqiNt2KbGdqkUKMojY
# SOLUM_ADMIN: the jackpot PDA is derived from coinMint + this wallet.
SOLUM_ADMIN=DWtwwotUi9v7ziFKLNwTpzGdPVZXPFQaRAGijZhJ6ZX8
SOLUM_VRF=switchboard
SOLUM_COUNTDOWN=300
SOLUM_EPOCH_LEN=3600
SOLUM_SNAP_MIN=480
SOLUM_SNAP_MAX=3000
SOLUM_FEE_POLL=20

# the five verified xStock prizes (mint · DWtw ops ATA · Token-2022)
SOLUM_STOCKS={"AAPLx":{"mint":"XsbEhLAtcf6HdfpFZ5xEMdqW8nfAvcsP5bdudRLJzJp","opsAccount":"BE6d2hMvyVDxsUfLmwWTnVh7GG3rKKLUgodnS8u9pzHd","tokenProgram":"TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"},"NVDAx":{"mint":"Xsc9qvGR1efVDFGLrVsmkzv3qi45LTBjeUKSPmx9qEh","opsAccount":"DX8pmsrH5cexNx3z44Uo3sCZtBeHM2mMo1VYV6yQFKc4","tokenProgram":"TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"},"TSLAx":{"mint":"XsDoVfqeBukxuZHWhdvWHBhgEHjGNst4MLodqsJHzoB","opsAccount":"BgAVsYFkmWAxFdSPEkHGBwMcfDfNcEYY31nJDHkGmXSL","tokenProgram":"TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"},"COINx":{"mint":"Xs7ZdzSHLU9ftNJsii5fCeJhoRWSC32SQGzGQtePxNu","opsAccount":"EAGon1pv5qV1AEWT6pZRwZAm41WSuNN8mRy8T8q22rSy","tokenProgram":"TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"},"MSTRx":{"mint":"XsP7xzNPvEHS1m6qfanPUGjNmdnmsLKEoNAnHjdxxyZ","opsAccount":"6tkhA4reb2D2n8oD5nhAQ1N34sz7y8Xs3vChZKy6kXtp","tokenProgram":"TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"}}
